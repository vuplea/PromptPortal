# Copy to .env next to docker-compose.yml; docker compose reads it
# automatically. Or export these in the shell / your deploy platform's
# environment settings instead. These configure the compose deployment (hub +
# the `server` workstation container); other workstations are configured on
# their own machines (see windows/install.ps1 and the README).

# The one secret. Gates browser sign-in (the username is always "pocketterm")
# and workstation registration alike. Make it long and random.
POCKETTERM_PASSWORD=change-me-long-random

# The server workstation's name in the UI.
#POCKETTERM_NODE_NAME=server

# Shell hosted in each session on the `server` workstation (a binary present
# in the workstation image; default bash).
#POCKETTERM_SHELL=bash

# Set when a reverse proxy you control (or tailscale serve) is the only way to
# reach the server; keys the brute-force lockout on X-Forwarded-For instead of
# the proxy's IP.
#POCKETTERM_TRUST_PROXY=1
